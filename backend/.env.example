# ════════════════════════════════════════════════════════════════════════════
#  GeoServe Admin Backend
#
#  OPTION A (Recommended): Don't run this backend at all.
#    Just run the backend from Project 1 (User/Worker Portal) and point
#    the admin frontend's VITE_API_URL at it. Both portals share one backend.
#
#  OPTION B: Run this as a standalone backend on a different port (5001)
#    so it doesn't clash with the User/Worker backend on port 5000.
#    NOTE: In this case the data/ folders are separate — use Option A in
#    production to keep data truly shared.
# ════════════════════════════════════════════════════════════════════════════

# Use 5001 so it doesn't clash with the User/Worker backend (5000)
PORT=5001

# Allow the Admin frontend origin
CORS_ORIGIN=http://localhost:5174,https://your-admin-app.vercel.app

# MUST match the JWT_SECRET in the User/Worker backend (if using shared backend)
JWT_SECRET=change_me_in_production_use_a_long_random_string

# Razorpay (leave blank for simulation)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_ACCOUNT_NUMBER=
