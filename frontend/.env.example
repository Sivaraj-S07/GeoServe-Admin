# ── API Base URL ──────────────────────────────────────────────────────────────
# IMPORTANT: Point this to the SAME backend as the User/Worker Portal.
# The Admin Portal and User/Worker Portal SHARE one backend.
#
# Development: leave blank (Vite proxy handles /api → localhost:5000)
# Production:  set to your deployed backend URL
VITE_API_URL=https://your-shared-backend.onrender.com/api
